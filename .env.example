# Cloudinary Configuration
# 1. Sign up at https://cloudinary.com
# 2. Copy your "Cloud Name" from your Cloudinary Dashboard
# 3. Paste it below to enable automatic high-speed CDN video streaming with auto-format (f_auto,q_auto) optimization.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Backend API Endpoint
VITE_API_BASE_URL=https://arc-backend-561q.onrender.com
